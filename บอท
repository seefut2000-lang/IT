                window.speechSynthesis.cancel();
                const utterance = new SpeechSynthesisUtterance(cleanText);
                utterance.lang = 'th-TH'; utterance.pitch = 0.75; utterance.rate = 1.05;    
                const icon = textBtn.querySelector('i');
                icon.className = "fa-solid fa-spinner fa-spin text-yellow-500";
