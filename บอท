<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEXUS AI - ULTIMATE WINGMAN V4</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Marked.js for Markdown parsing -->
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <!-- Google Fonts: Chakra Petch & JetBrains Mono -->
    <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@300;400;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    
    <style>
        body { 
            font-family: 'Chakra Petch', sans-serif;
            background-color: #030303; 
            color: #00ffcc; 
            transition: filter 0.1s;
        }
        .mono-font { font-family: 'JetBrains Mono', monospace; }
        
        /* ซ่อน Scrollbar */
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

        /* ตกแต่งเนื้อหา Markdown สไตล์ Cyberpunk Terminal */
        .markdown-body { color: #cbd5e1; }
        .markdown-body h1, .markdown-body h2, .markdown-body h3 {
            font-weight: 700; margin-top: 1.25em; margin-bottom: 0.5em; color: #00ffcc;
            text-shadow: 0 0 8px rgba(0, 255, 204, 0.4);
            text-transform: uppercase; letter-spacing: 1.5px;
            font-family: 'Chakra Petch', sans-serif;
        }
        .markdown-body p { margin-bottom: 0.75em; line-height: 1.6; }
        .markdown-body ul, .markdown-body ol { padding-left: 1.5em; margin-bottom: 1em; }
        .markdown-body ul { list-style-type: square; }
        .markdown-body ul li::marker { color: #00ffcc; }
        .markdown-body code {
            background-color: #0d0d0d; padding: 0.2em 0.4em; border-radius: 0.25rem; 
            font-family: 'JetBrains Mono', monospace; color: #facc15; border: 1px solid #222;
        }
        .markdown-body pre {
            background-color: #050505; padding: 1.25em; border-radius: 0.5rem; overflow-x: auto; 
            margin-bottom: 1.25em; border-left: 4px solid #00ffcc; border-top: 1px solid #222; border-right: 1px solid #222; border-bottom: 1px solid #222;
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
            position: relative;
        }
        .markdown-body pre code { background-color: transparent; padding: 0; color: #38bdf8; border: none; }

        /* แอนิเมชัน Pulse สัญญาณแกน */
        @keyframes core-glow {
            0% { box-shadow: 0 0 10px rgba(0, 255, 204, 0.3), inset 0 0 5px rgba(0, 255, 204, 0.2); }
            50% { box-shadow: 0 0 25px rgba(0, 255, 204, 0.7), inset 0 0 15px rgba(0, 255, 204, 0.5); }
            100% { box-shadow: 0 0 10px rgba(0, 255, 204, 0.3), inset 0 0 5px rgba(0, 255, 204, 0.2); }
        }
        .tech-core-pulse { animation: core-glow 3s infinite ease-in-out; }

        /* สไตล์กริดพื้นหลัง */
        .bg-cyber-grid {
            background-size: 40px 40px;
            background-image: linear-gradient(to right, rgba(0, 255, 204, 0.02) 1px, transparent 1px),
                              linear-gradient(to bottom, rgba(0, 255, 204, 0.02) 1px, transparent 1px);
        }

        /* Matrix Scan Effect */
        @keyframes scanline {
            0% { transform: translateY(-100%); }
            100% { transform: translateY(100%); }
        }
        .scanline-effect::after {
            content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 4px;
            background: linear-gradient(to bottom, transparent, rgba(0, 255, 204, 0.4), transparent);
            animation: scanline 4s linear infinite;
        }

        /* บลัดดิ้งและปุ่มสไตล์แฮกเกอร์ */
        .hacker-btn {
            border: 1px solid rgba(0, 255, 204, 0.3);
            background: rgba(0, 255, 204, 0.03);
            transition: all 0.2s ease;
        }
        .hacker-btn:hover {
            border-color: #00ffcc;
            background: rgba(0, 255, 204, 0.1);
            text-shadow: 0 0 8px rgba(0, 255, 204, 0.6);
            box-shadow: 0 0 12px rgba(0, 255, 204, 0.2);
        }
        .hacker-btn:active { transform: scale(0.97); }

        /* ตัวกระพริบ Terminal */
        .cursor-blink {
            display: inline-block; width: 8px; height: 16px; background-color: #00ffcc;
            animation: blink 1s step-end infinite; vertical-align: middle;
        }
        @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

        /* Canvas สายฝน Matrix ด้านข้าง */
        #matrix-canvas {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            pointer-events: none; opacity: 0.04; z-index: 0;
        }

        /* RAGE MODE (Glitch & Shake Effects) */
        .glitch-anim {
            animation: shake 0.35s cubic-bezier(.36,.07,.19,.97) both;
            filter: contrast(150%) hue-rotate(45deg) saturate(150%);
        }
        @keyframes shake {
            10%, 90% { transform: translate3d(-3px, 0, 0) rotate(-1deg); }
            20%, 80% { transform: translate3d(5px, 0, 0) rotate(1deg); }
            30%, 50%, 70% { transform: translate3d(-8px, 0, 0) rotate(-2deg); }
            40%, 60% { transform: translate3d(8px, 0, 0) rotate(2deg); }
        }

        /* ปุ่มไมค์อัดเสียง */
        .mic-recording {
            animation: pulse-red 1s infinite;
            color: #ef4444 !important; /* Red */
        }
        @keyframes pulse-red {
            0% { text-shadow: 0 0 5px #ef4444; }
            50% { text-shadow: 0 0 20px #ef4444, 0 0 30px #ef4444; }
            100% { text-shadow: 0 0 5px #ef4444; }
        }
    </style>
</head>
