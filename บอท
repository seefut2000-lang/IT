                saveSessions(); 
            } catch (error) {
                activeSession.history.pop();
                triggerRageGlitch(); // สั่นจอตอน Error
                appendMessage(`**[SYSTEM REJECTED ERROR]** ${error.message} \n\n*ระบบกูขัดข้องเฉยเลยสัส ป้อนคำสั่งส่งมาใหม่อีกรอบดิ๊!*`, 'model', true);
            } finally {
                sendBtn.disabled = false; loadingIndicator.classList.add('hidden');
                scrollToBottom(); userInput.focus();
            }
        });

        async function callGeminiAPI(maxRetries = 5) {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
            const activeHistory = sessions[currentSessionId].history;

            const safeHistory = activeHistory.map(msg => {
                let textPart = msg.parts.find(p => p.text)?.text || '';
                let hasImage = msg.parts.some(p => p.inlineData);
                if (hasImage && !textPart.includes('[SYSTEM DATA FRAME]')) {
                    textPart = "[SYSTEM DATA FRAME: IMAGE INTEGRATED] " + textPart;
                }
                return { role: msg.role, parts: [{ text: textPart }] };
            });

            const payload = {
                contents: safeHistory,
                systemInstruction: { parts: [{ text: SYSTEM_INSTRUCTION }] },
                tools: [{ "google_search": {} }] 
            };

            for (let attempt = 0; attempt < maxRetries; attempt++) {
                try {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    if (!response.ok) throw new Error(`HTTP Error: ${response.status}`);
                    const data = await response.json();
                    
                    if (data.candidates && data.candidates.length > 0) {
                        const ans = data.candidates[0].content.parts[0].text;
                        // ถ้าคำตอบที่ได้มีคำหยาบมากๆ ให้สั่งจอ Glitch (Rage Mode) ทันที
                        if (rageKeywords.some(w => ans.includes(w))) {
                            triggerRageGlitch();
                        }
                        return ans;
                    } else {
                        throw new Error('Host disconnected unexpectedly');
                    }
                } catch (error) {
                    if (attempt === maxRetries - 1) throw error;
                    const delay = Math.pow(2, attempt) * 1000;
                    await new Promise(resolve => setTimeout(resolve, delay));
                }
            }
        }

        // ==========================================
        // Render Messages
        // ==========================================
        function appendMessage(text, role, isError = false, isLoadingFromMemory = false) {
            const wrapperDiv = document.createElement('div');
            wrapperDiv.className = `chat-bubble-wrapper flex ${role === 'user' ? 'justify-end' : 'justify-start'}`;
            const bubbleDiv = document.createElement('div');
            
            if (role === 'user') {
                bubbleDiv.className = 'max-w-[85%] md:max-w-[70%] bg-[#05111a]/85 border border-[#00ffcc]/40 text-slate-100 p-4 shadow-xl text-sm md:text-base font-sans relative';
                bubbleDiv.innerHTML = `<div class="absolute top-0 right-0 w-3.5 h-3.5 border-t-2 border-r-2 border-[#00ffcc]"></div>
                                       <div class="absolute bottom-0 left-0 w-3.5 h-3.5 border-b-2 border-l-2 border-[#00ffcc]/30"></div>`;
                
                let safeText = text.replace(/</g, "&lt;").replace(/>/g, "&gt;");
                if(isLoadingFromMemory && text.includes('[SYSTEM DATA FRAME: IMAGE INTEGRATED]')) {
                    safeText = safeText.replace('[SYSTEM DATA FRAME: IMAGE INTEGRATED]', '<span class="text-[#00ffcc] text-xs font-bold mono-font uppercase tracking-wider"><i class="fa-solid fa-file-image"></i> [IMAGE DATA BLOCK INSTANTIATED]</span><br>');
                } else if (!isLoadingFromMemory) { safeText = text; }
                bubbleDiv.innerHTML += `<div class="whitespace-pre-wrap">${safeText}</div>`;
            } else {
                const errorClass = isError ? 'border-[#ff3366] bg-[#1a0208] text-[#ffb3c6]' : 'border-[#333] border-l-[#00ffcc] bg-black/95 text-slate-300';
                bubbleDiv.className = `max-w-[85%] md:max-w-[75%] border border-l-[5px] ${errorClass} p-5 shadow-2xl relative markdown-body text-sm md:text-base leading-relaxed overflow-hidden`;
                
                let parsedHtml = marked.parse(text);
                const tempDiv = document.createElement('div');
                tempDiv.innerHTML = parsedHtml;
                
                const preElements = tempDiv.querySelectorAll('pre');
                preElements.forEach(pre => {
                    const code = pre.querySelector('code');
                    if (code) {
                        const codeString = code.innerText;
                        const encodedCode = encodeURIComponent(codeString);
                        const headerPanel = document.createElement('div');
                        headerPanel.className = 'flex justify-between items-center bg-[#0d0d0d] px-3.5 py-2 border-b border-[#222] text-[10px] text-slate-400 font-mono tracking-wider select-none rounded-t-lg -mx-5 -mt-5 mb-3';
                        headerPanel.innerHTML = `
                            <span><i class="fa-solid fa-code text-[#00ffcc]"></i> EXECUTABLE_BLOCK</span>
                            <button onclick="copyCode(this, '${encodedCode}')" class="text-xs text-[#00ffcc] hover:text-white transition font-bold"><i class="fa-solid fa-copy mr-1"></i> COPY CODE</button>
                        `;
                        pre.insertBefore(headerPanel, pre.firstChild);
                    }
                });
                bubbleDiv.innerHTML = tempDiv.innerHTML;

                if (!isError) {
                    const controlBar = document.createElement('div');
                    controlBar.className = 'flex justify-end mt-4 pt-2 border-t border-[#222]/50 text-xs text-slate-500 font-mono gap-4 select-none';
                    const encodedResponseText = encodeURIComponent(text);
                    controlBar.innerHTML = `
                        <span>NEXUS HARCORE v4</span>
                        <button onclick="speakText(this, decodeURIComponent('${encodedResponseText}'))" class="hover:text-white text-[#00ffcc] flex items-center gap-1 transition" title="อ่านออกเสียงด้วย AI">
                            <i class="fa-solid fa-volume-high"></i> SPEAK
                        </button>
                    `;
                    bubbleDiv.appendChild(controlBar);
                }
            }
            wrapperDiv.appendChild(bubbleDiv);
            chatContainer.appendChild(wrapperDiv);
            if(!isLoadingFromMemory) scrollToBottom();
        }
        function scrollToBottom() { chatContainer.scrollTo({ top: chatContainer.scrollHeight, behavior: 'smooth' }); }
    </script>
