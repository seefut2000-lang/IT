        function loadSessions() {
            const savedThreads = localStorage.getItem('nexus_v4_threads');
            const savedActiveId = localStorage.getItem('nexus_v4_active_thread_id');
            
            if (savedThreads) {
                try { sessions = JSON.parse(savedThreads); } catch (e) { sessions = {}; }
