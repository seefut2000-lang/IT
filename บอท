                utterance.onerror = () => { icon.className = "fa-solid fa-volume-high text-[#00ffcc] hover:text-white"; };
                window.speechSynthesis.speak(utterance);
            } else {
                alert("เบราว์เซอร์โง่ๆ ของมึงไม่รองรับระบบเสียงพูดว่ะสัส!");
